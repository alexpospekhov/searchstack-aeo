Output demo/searchstack-demo.gif
Set Shell bash
Set FontSize 15
Set Width 1100
Set Height 700
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set CursorBlink false

Hide
Type `export PS1="$ "`
Enter
Sleep 200ms
Type `cd /tmp`
Enter
Sleep 200ms
Type `alias searchstack="python3 '/Users/Alexvs/HYPERFOCUS OS/Claude/hyperfocus/My Public Gits/SEO:AEO/demo/demo.py'"`
Enter
Sleep 200ms
Type "clear"
Enter
Sleep 300ms
Show

# AEO Check
Type "searchstack ai"
Sleep 500ms
Enter
Sleep 5s

# GEO Check
Type "searchstack geo"
Sleep 500ms
Enter
Sleep 5s

# GSC Rankings
Type "searchstack gsc"
Sleep 500ms
Enter
Sleep 4s

# Position Tracking
Type "searchstack track"
Sleep 500ms
Enter
Sleep 4s

# Report
Type "searchstack report"
Sleep 500ms
Enter
Sleep 6s
