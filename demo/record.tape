Output demo/searchstack-demo.gif
Set Shell bash
Set FontSize 15
Set Width 1100
Set Height 700
Set Padding 20
Set Theme "Catppuccin Mocha"
Set TypingSpeed 50ms
Set CursorBlink false

Hide
Type `cd "/Users/Alexvs/HYPERFOCUS OS/Claude/hyperfocus/My Public Gits/SEO:AEO/"`
Enter
Sleep 500ms
Show

# AEO Check
Type "searchstack ai"
Sleep 500ms
Enter
Hide
Type "python3 demo/demo.py ai"
Enter
Show
Sleep 5s

# GEO Check
Type "searchstack geo"
Sleep 500ms
Enter
Hide
Type "python3 demo/demo.py geo"
Enter
Show
Sleep 5s

# GSC Rankings
Type "searchstack gsc"
Sleep 500ms
Enter
Hide
Type "python3 demo/demo.py gsc"
Enter
Show
Sleep 4s

# Position Tracking
Type "searchstack track"
Sleep 500ms
Enter
Hide
Type "python3 demo/demo.py track"
Enter
Show
Sleep 4s

# Report
Type "searchstack report"
Sleep 500ms
Enter
Hide
Type "python3 demo/demo.py report"
Enter
Show
Sleep 6s
